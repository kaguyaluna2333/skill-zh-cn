#!/usr/bin/env bash
# hooks/session-start — skill-zh-cn 的 SessionStart hook（CC + zcode 通用）。
#
# 策略（混合：hook scan + 提示 agent 翻）：
#   - 同步 scan 出待译队列（不调 LLM，快），写 <cacheDir>/.queue.json
#   - 队列非空 → additionalContext 提示 agent 运行 /skill-zh-cn 用本宿主能力汉化
#   - 翻译由本宿主 agent 完成（/skill-zh-cn command），不 spawn 外部 CLI、不调 API
#
# 这样「装在谁身上就让谁的 agent 翻」，无需 claude CLI 或 API key。
# 默认始终启用 scan（只读，无副作用）；翻译由 agent 主动触发。

set -uo pipefail

# 递归 guard：translate.js spawn claude CLI 时设 SKILL_I18N_HOOK=1 防递归；
# 内层会话若再触发 SessionStart，直接读 stdin 输出空 JSON 短路退出，
# 与 translate.js 的 SPAWN_GUARD_ENV 闭环。
if [ "${SKILL_I18N_HOOK:-0}" = "1" ]; then
    read -r _INPUT 2>/dev/null || true
    echo '{}'
    exit 0
fi

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

# hosts 探测本宿主（CC 还是 zcode，由 CLAUDE_PLUGIN_ROOT 反推或特征扫描）
# 一行 eval 替代旧 tab 分隔 + 四段字符串切割；探测失败留空变量，下面兜底
USER_ROOT=""
PLUGIN_ROOT_HOST=""
CACHE_DIR=""
eval "$(node "$PLUGIN_ROOT/core/lib/hosts.js" --shell-eval 2>/dev/null)" || true
# shell-eval 把「宿主 pluginRoot」写到 PLUGIN_ROOT；本脚本里 PLUGIN_ROOT 专指
# skill-zh-cn 插件根（下面要拼 $PLUGIN_ROOT/core/scan.js 路径）——把它转存到
# PLUGIN_ROOT_HOST 后恢复原值
PLUGIN_ROOT_HOST="${PLUGIN_ROOT:-}"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

# scan 待译项（同步，不调 LLM）
# 一次 spawn 完成 scan + count：scan.js 的 --print-count 直接把 toTranslate.length
# 写入文件，省掉第二次 node 冷启动（旧实现先 spawn scan.js 再 spawn node -e 数 count）
# TODO(perf): 全树扫描无 mtime 缓存——每次 SessionStart 都遍历所有 skill/command 文件
# 解析 frontmatter。可加 per-path mtime 缓存（路径 → mtime → 跳过解析）减少常驻开销。
COUNT=0
if [ -n "$USER_ROOT" ] && [ -n "$PLUGIN_ROOT_HOST" ] && [ -d "$PLUGIN_ROOT/core" ]; then
    mkdir -p "$CACHE_DIR" 2>/dev/null || true
    node "$PLUGIN_ROOT/core/scan.js" \
        --user-root "$USER_ROOT" \
        --plugin-root "$PLUGIN_ROOT_HOST" \
        --cache "$CACHE_DIR/translations.json" \
        --output "$CACHE_DIR/.queue.json" \
        --print-count "$CACHE_DIR/.count" >/dev/null 2>&1 || true
    COUNT="$(cat "$CACHE_DIR/.count" 2>/dev/null || echo 0)"
fi

# SessionStart hook 协议：读 stdin
read -r INPUT 2>/dev/null || true

# 队列非空 → 提示 agent 用 /skill-zh-cn 汉化（由本宿主 agent 翻译）
if [ "${COUNT:-0}" -gt 0 ] 2>/dev/null; then
    node -e '
        const c = process.argv[1];
        process.stdout.write(JSON.stringify({
            hookSpecificOutput: {
                hookEventName: "SessionStart",
                additionalContext: "## skill 说明汉化\n\n检测到 " + c + " 条待汉化的 skill/命令说明（英文 description）。运行 /skill-zh-cn 用你（本宿主）的翻译能力汉化——装在本宿主、由本宿主翻译，无需外部 API；已汉化的下次自动跳过。"
            }
        }));
    ' "$COUNT"
else
    echo '{}'
fi
